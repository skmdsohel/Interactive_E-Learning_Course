# ===== App =====
APP_NAME=LMS API
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

# ===== Server =====
HOST=0.0.0.0
PORT=8000

# ===== Logging =====
LOG_LEVEL=INFO
LOG_JSON=false

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Database (MySQL) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=lms_user
DB_PASSWORD=lms_password
DB_NAME=lms_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ===== Storage =====
STORAGE_ROOT=storage
VIDEOS_SUBDIR=videos
THUMBNAILS_SUBDIR=thumbnails
VIDEO_STREAM_CHUNK_SIZE=1048576
THUMBNAILS_URL_PREFIX=/static/thumbnails

# ===== Content sync =====
# Auto-scan storage/videos on every startup and refresh the catalog.
AUTO_SEED_ON_STARTUP=true
# Remove courses whose folder was deleted from disk.
AUTO_SEED_PRUNE_MISSING=true

# ===== Auth (Google Sign-In) =====
# Create an OAuth 2.0 Web Client in Google Cloud Console.
# Authorized JavaScript origins MUST include: http://localhost:5173
# Paste the same client ID here AND into frontend/.env as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
# Secret for the app's own session JWT. Replace with a long random string in production.
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# Comma-separated emails promoted to the "admin" role on every sign-in.
# Everyone NOT in this list signs in as a "learner".