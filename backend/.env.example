# ===== App =====
APP_NAME=LMS API
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

# ===== Server =====
HOST=0.0.0.0
PORT=8000

# ===== Logging =====
LOG_LEVEL=INFO
LOG_JSON=false

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Database (MySQL) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=lms_user
DB_PASSWORD=lms_password
DB_NAME=lms_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ===== Storage =====
STORAGE_ROOT=storage
VIDEOS_SUBDIR=videos
THUMBNAILS_SUBDIR=thumbnails
VIDEO_STREAM_CHUNK_SIZE=1048576
THUMBNAILS_URL_PREFIX=/static/thumbnails
