# Base URL used by axios. In dev the Vite proxy forwards /api/* to the backend.
VITE_API_BASE_URL=/api/v1

# Target the dev-server proxy forwards /api requests to.
VITE_API_PROXY_TARGET=http://localhost:8000

# Google OAuth 2.0 Web Client ID (same value as backend GOOGLE_CLIENT_ID).
# Create one at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include http://localhost:5173
VITE_GOOGLE_CLIENT_ID=
