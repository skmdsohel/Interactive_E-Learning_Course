# Base URL used by axios.
# Dev: leave as "/api/v1" — the Vite dev proxy forwards to VITE_API_PROXY_TARGET.
# Prod (Render Static Site): set to the FULL backend URL, e.g.
#   https://learnsphere-backend.onrender.com/api/v1
VITE_API_BASE_URL=/api/v1

# Target the dev-server proxy forwards /api requests to (dev only; ignored in prod).
VITE_API_PROXY_TARGET=http://localhost:8000

# Google OAuth 2.0 Web Client ID (same value as backend GOOGLE_CLIENT_ID).
# Create one at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include http://localhost:5173 AND your
# deployed frontend origin, e.g. https://learnsphere-frontend.onrender.com
VITE_GOOGLE_CLIENT_ID=
